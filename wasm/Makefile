# Emscripten build of the Moscow ML (Caml Light) bytecode runtime.
#
# Only the C runtime is compiled to Wasm. The compiler/toplevel stays as
# Moscow ML bytecode (built natively from the SAME tree) and is loaded as
# data. prims.c/opnames.h/jumptbl.h are generated by the native build, so
# `make world` in vendor/mosml/src must run first — this also guarantees the
# primitive table matches the bytecode artifacts.
#
# Sources are copied into build/ so our wasm32 m.h/s.h can shadow the
# native-configured ones without touching the vendor tree.

RUNTIME := ../vendor/mosml/src/runtime
BUILD   := build
OUT     := ../dist

SRCS := interp.c expand.c misc.c stacks.c fix_code.c main.c fail.c signals.c \
  freelist.c major_gc.c minor_gc.c memory.c alloc.c roots.c \
  compare.c ints.c floats.c str.c io.c \
  extern.c externcp.c intern.c interncp.c \
  hash.c sys.c meta.c parsing.c lexing.c gc_ctrl.c mosml.c unix.c \
  runtime.c md5sum.c callback.c dynlib.c prims.c

CFLAGS := -std=gnu89 -Dunix -DTHREADED -O2 \
  -Wno-implicit-function-declaration -Wno-return-type

LDFLAGS := \
  -sMODULARIZE=1 -sEXPORT_ES6=1 -sEXPORT_NAME=createMosmlRuntime \
  -sALLOW_MEMORY_GROWTH=1 \
  -sEXIT_RUNTIME=1 -sINVOKE_RUN=0 \
  -sFORCE_FILESYSTEM=1 \
  -sSTACK_SIZE=8388608 \
  -sEXPORTED_RUNTIME_METHODS=FS,callMain \
  -sENVIRONMENT=web,worker,node \
  -sINCOMING_MODULE_JS_API=preRun,print,printErr,stdin,onExit,arguments,noExitRuntime

all: $(OUT)/camlrunm.mjs $(OUT)/camlrunm-node.mjs

$(BUILD)/copied.stamp: $(wildcard $(RUNTIME)/*.c $(RUNTIME)/*.h) m.h s.h
	mkdir -p $(BUILD)
	cp $(RUNTIME)/*.c $(RUNTIME)/*.h $(BUILD)/
	cp m.h s.h $(BUILD)/
	# Wasm fix: [-sizeof(value)] is a huge UNSIGNED index; clang folds it
	# into the load's unsigned offset immediate and the 33-bit effective
	# address traps. A signed index compiles to a wrapping i32.add.
	sed 's/\[-sizeof(value)\]/[-(long)sizeof(value)]/' \
	  $(RUNTIME)/mlvalues.h > $(BUILD)/mlvalues.h
	touch $@

# Browser artifact: in-memory filesystem (MEMFS).
$(OUT)/camlrunm.mjs: $(BUILD)/copied.stamp
	mkdir -p $(OUT)
	cd $(BUILD) && emcc $(CFLAGS) $(SRCS) $(LDFLAGS) \
	  -o ../$(OUT)/camlrunm.mjs

# Node artifact: direct host-filesystem access (NODERAWFS). Used to run the
# Moscow ML build's bytecode steps under the wasm32 runtime, so that all
# bytecode artifacts come out in 32-bit extern format.
$(OUT)/camlrunm-node.mjs: $(BUILD)/copied.stamp
	mkdir -p $(OUT)
	cd $(BUILD) && emcc $(CFLAGS) $(SRCS) $(LDFLAGS) -sNODERAWFS=1 \
	  -sENVIRONMENT=node -o ../$(OUT)/camlrunm-node.mjs

clean:
	rm -rf $(BUILD) $(OUT)/camlrunm.mjs $(OUT)/camlrunm.wasm \
	  $(OUT)/camlrunm-node.mjs $(OUT)/camlrunm-node.wasm

.PHONY: all clean
